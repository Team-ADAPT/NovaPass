# Copy to .env and fill in values before running.
# NEVER commit .env to version control.

# ── Database ────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/novapass
DB_USERNAME=postgres
DB_PASSWORD=change_me_strong_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_256_bit_secret_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ── WebAuthn (Passkeys) ───────────────────────────────────────────────────────
# RP_ID = domain only, no protocol or port
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=NovaPass
WEBAUTHN_RP_ORIGIN=http://localhost:3000

# ── Admin account (optional) ─────────────────────────────────────────────────
# If set, an admin user is created automatically on first backend startup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_strong_admin_password
ADMIN_USERNAME=admin

# ── Frontend ─────────────────────────────────────────────────────────────────
# Used by Next.js to reach the backend API
NEXT_PUBLIC_API_URL=http://localhost:8080
