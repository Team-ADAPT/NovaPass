# Copy to .env and fill in values before running docker-compose
# NEVER commit .env to version control

# Database
DB_USERNAME=postgres
DB_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT — must be at least 32 random characters
JWT_SECRET=change_me_to_a_random_256_bit_secret_key_here

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://app.novapass.io

# API URL used by the web frontend
API_URL=https://app.novapass.io
